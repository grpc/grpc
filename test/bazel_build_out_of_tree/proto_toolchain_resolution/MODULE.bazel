# A small Bazel module to verify that
# `generate_py`, `py_proto_library`, `generate_cc`, `generate_objc`
# work when `--incompatible_enable_proto_toolchain_resolution` is enabled.
# Context:
# - https://github.com/grpc/grpc/issues/41273
# - https://github.com/protocolbuffers/protobuf/issues/19558
module(
    name = "grpc_proto_toolchain_resolution_test",
)

bazel_dep(name = "grpc")
local_path_override(
    module_name = "grpc",
    path = "../../..",
)

bazel_dep(name = "protobuf", version = "35.0")
bazel_dep(name = "bazel_skylib", version = "1.9.0")
