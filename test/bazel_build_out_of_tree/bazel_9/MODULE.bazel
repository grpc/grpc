# A build test that gives a working combination of bazel 9 compatible packages.
# The versions can be newer than what we're using in grpc/MODULE.bazel, because
# bazel will ignore overrides in non-root modules, See
# https://bazel.build/external/module#overrides
#
# To view the resolved dependency graph, run `bazel mod graph`.

module(
    name = "grpc_build_test",
)

bazel_dep(name = "grpc")
local_path_override(
    module_name = "grpc",
    path = "../../../",
)

# Bump to newer package versions that have good bazel 9 support.
bazel_dep(name = "c-ares", version = "1.34.6")
bazel_dep(name = "abseil-cpp", version = "20260526.0")
