{
  "name": "farazahmadk/grpc_ext",
  "type": "php-ext",
  "description": "gRPC C extension for PHP, packaged for PIE support",
  "keywords": [
    "rpc"
  ],
  "homepage": "https://grpc.io",
  "license": "Apache-2.0",
  "provide": {
    "ext-grpc": "self.version"
  },
  "require-dev": {
    "google/auth": "^v1.3.0"
  },
  "php-ext": {
    "extension-name": "grpc",
    "download-url-method": [
      "pre-packaged-source"
    ]
  },
  "require": {
    "php": ">=8.1"
  }
}
