from typing import Any, Optional

EOF: Any

class BaseError(Exception): ...
class UsageError(BaseError): ...
class InternalError(BaseError): ...

def build_census_context() -> Any: ...

class CallCredentials: ...
class ChannelCredentials: ...

class AioRpcStatus(Exception):
    def __init__(self, code: int, details: str, trailing_metadata: Optional[tuple], debug_error_string: Optional[str]) -> None: ...
    def code(self) -> int: ...
    def details(self) -> str: ...
    def trailing_metadata(self) -> tuple: ...
    def debug_error_string(self) -> str: ...

class AioChannel:
    target: bytes
    def __init__(self, target: bytes, options: tuple, credentials: Optional[ChannelCredentials], loop: Any) -> None: ...
    def call(self, method: bytes, deadline: Optional[float], python_call_credentials: Any, wait_for_ready: Optional[bool]) -> _AioCall: ...

class _AioCall:
    _initial_metadata: tuple
    _status: AioRpcStatus
    def __init__(self, channel: AioChannel, deadline: Optional[float], method: bytes, call_credentials: Optional[CallCredentials], wait_for_ready: Optional[bool]) -> None: ...
    def add_done_callback(self, callback: Any) -> None: ...
    def time_remaining(self) -> Optional[float]: ...
    def cancel(self, details: str) -> None: ...
    def done(self) -> bool: ...
    def cancelled(self) -> bool: ...
    async def status(self) -> AioRpcStatus: ...
    def is_ok(self) -> bool: ...
    async def initial_metadata(self) -> tuple: ...
    def is_locally_cancelled(self) -> bool: ...
    def set_internal_error(self, error_str: str) -> None: ...
    async def unary_unary(self, request: bytes, outbound_initial_metadata: tuple, context: Optional[Any] = ...) -> bytes: ...
    async def receive_serialized_message(self) -> Any: ...
    async def send_serialized_message(self, message: bytes) -> None: ...
    async def send_receive_close(self) -> None: ...
    async def initiate_unary_stream(self, request: bytes, outbound_initial_metadata: tuple, context: Optional[Any] = ...) -> None: ...
    async def stream_unary(self, outbound_initial_metadata: tuple, metadata_sent_observer: Any, context: Optional[Any] = ...) -> bytes: ...
    async def initiate_stream_stream(self, outbound_initial_metadata: tuple, metadata_sent_observer: Any, context: Optional[Any] = ...) -> None: ...